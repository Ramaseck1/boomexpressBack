// ═══════════════════════════════════════════════════════════════════════════
// SCHEMA MIS À JOUR — rien n'est supprimé, uniquement des ajouts (marqués ✅ NEW)
// Remplacez votre prisma/schema.prisma par celui-ci, puis :
//   npx prisma migrate dev --name add_client_user
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  nom               String
  prenom            String
  telephone         String?             @unique
  email             String?             @unique
  password          String
  role              Role
  statut            String              @default("actif")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  livreur           Livreur?
  client            Client?             // ✅ NEW — lien 1-1 vers le profil client
  PasswordResetCode PasswordResetCode[]
}

model PasswordResetCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  verified  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model Client {
  id                    Int      @id @default(autoincrement())
  userId                Int?     @unique // ✅ NEW — null pour les clients "walk-in" créés par l'admin (comportement existant inchangé)
  user                  User?    @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ NEW
  nom                   String
  prenom                String
  telephone             String
  adresse               String
  adresseLivraison      String
  telephoneDestinataire String
  latActuelle           Float?   // ✅ NEW — position GPS live du client (pour proposer le livreur le plus proche)
  lngActuelle           Float?   // ✅ NEW
  pushToken             String?  // ✅ NEW — notifications push (livreur en route, etc.)
  createdAt             DateTime @default(now())

  commandes Commande[]
}

model Carte {
  id      Int    @id @default(autoincrement())
  commune String
  lat     Float
  lng     Float
}

model Commande {
  id             Int      @id @default(autoincrement())
  clientId       Int
  client         Client   @relation(fields: [clientId], references: [id])
  montant        Float
  commission     Float
  commissionPaye Boolean  @default(false)
  createdAt      DateTime @default(now())
  statut         String   @default("en_attente")
  deletedAt      DateTime?

  // ✅ NEW — adresses/coordonnées propres à CETTE commande (le flux admin existant
  // continue de fonctionner sans ces champs, via client.adresse / client.adresseLivraison)
  adresseDepart          String?
  adresseLivraison       String?
  telephoneDestinataire  String?
  departLat              Float?
  departLng              Float?
  destLat                Float?
  destLng                Float?
  annulePar              String?  // "client" | "admin" | null

  livraisons Livraison[] @relation("CommandeLivraison")
}

model Livreur {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  disponible       Boolean   @default(false)
  profilValide     Boolean   @default(false)
  estBloque        Boolean   @default(false)
  commissionDue    Float     @default(0)
  derniereActivite DateTime?
  latActuelle      Float?
  lngActuelle      Float?
  estVerifie       Boolean   @default(false)
  pushToken        String?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  livraisons  Livraison[]
  commissions PaiementCommission[]
  blocages    Blocage[]
  documents   DocumentLivreur?
}

model DocumentLivreur {
  id        Int @id @default(autoincrement())
  livreurId Int @unique

  cniRectoUrl      String
  cniRectoPublicId String
  cniVersoUrl      String
  cniVersoPublicId String

  permisUrl         String?
  permisPublicId    String?
  assuranceUrl      String?
  assurancePublicId String?
  recepisseUrl      String?
  recepissePublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  livreur Livreur @relation(fields: [livreurId], references: [id])
}

model Livraison {
  id             Int       @id @default(autoincrement())
  commandeId     Int
  livreurId      Int
  statut         String
  dateLivraison  DateTime?
  destinationLat Float?
  destinationLng Float?
  commande       Commande  @relation(fields: [commandeId], references: [id], name: "CommandeLivraison")
  livreur        Livreur   @relation(fields: [livreurId], references: [id])
}

model PaiementCommission {
  id        Int      @id @default(autoincrement())
  livreurId Int
  montant   Float
  statut    String
  createdAt DateTime @default(now())
  livreur   Livreur  @relation(fields: [livreurId], references: [id])
}

model Blocage {
  id        Int     @id @default(autoincrement())
  livreurId Int
  raison    String
  actif     Boolean @default(true)
  livreur   Livreur @relation(fields: [livreurId], references: [id])
}

enum Role {
  ADMIN
  LIVREUR
  SUPERADMIN
  CLIENT // ✅ NEW
}
