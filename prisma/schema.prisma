generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                 @id @default(autoincrement())
  nom               String
  prenom            String
  telephone         String?             @unique
  email             String?             @unique
  password          String
  role              Role
  statut            String              @default("actif")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  livreur           Livreur?
  PasswordResetCode PasswordResetCode[]
}

model PasswordResetCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  verified  Boolean  @default(false) // ← ajouter ce champ

  user User @relation(fields: [userId], references: [id])
}

model Client {
  id                    Int      @id @default(autoincrement())
  nom                   String
  prenom                String
  telephone             String
  adresse               String
  adresseLivraison      String
  telephoneDestinataire String
  createdAt             DateTime @default(now())

  commandes Commande[]
}

model Carte {
  id      Int    @id @default(autoincrement())
  commune String
  lat     Float
  lng     Float
}

model Commande {
  id             Int      @id @default(autoincrement())
  clientId       Int
  client         Client   @relation(fields: [clientId], references: [id])
  montant        Float
  commission     Float
  commissionPaye Boolean  @default(false)
  createdAt      DateTime @default(now())
  statut         String   @default("en_attente")
  deletedAt DateTime?

  livraisons Livraison[] @relation("CommandeLivraison")
}

model Livreur {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique
  disponible       Boolean   @default(false)
  profilValide     Boolean   @default(false)
  estBloque        Boolean   @default(false)
  commissionDue    Float     @default(0)
  derniereActivite DateTime?
  latActuelle      Float?
  lngActuelle      Float?
  estVerifie       Boolean   @default(false)
  pushToken String?

  user        User                 @relation(fields: [userId], references: [id])
  livraisons  Livraison[]
  commissions PaiementCommission[]
  blocages    Blocage[]
  documents   DocumentLivreur? // ✅ ? car @unique sur livreurId = relation 1-to-1
}

model DocumentLivreur {
  id        Int @id @default(autoincrement())
  livreurId Int @unique

  // Obligatoire
  cniRectoUrl      String
  cniRectoPublicId String
  cniVersoUrl      String
  cniVersoPublicId String

  // Optionnels
  permisUrl         String?
  permisPublicId    String?
  assuranceUrl      String?
  assurancePublicId String?
  recepisseUrl      String?
  recepissePublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  livreur Livreur @relation(fields: [livreurId], references: [id])
}

model Livraison {
  id             Int       @id @default(autoincrement())
  commandeId     Int
  livreurId      Int
  statut         String
  dateLivraison  DateTime?
  destinationLat Float? // 📍 manquait
  destinationLng Float?
  commande       Commande  @relation(fields: [commandeId], references: [id], name: "CommandeLivraison")
  livreur        Livreur   @relation(fields: [livreurId], references: [id])
}

model PaiementCommission {
  id        Int      @id @default(autoincrement())
  livreurId Int
  montant   Float
  statut    String
  createdAt DateTime @default(now())
  livreur   Livreur  @relation(fields: [livreurId], references: [id])
}

model Blocage {
  id        Int     @id @default(autoincrement())
  livreurId Int
  raison    String
  actif     Boolean @default(true)
  livreur   Livreur @relation(fields: [livreurId], references: [id])
}

enum Role {
  ADMIN
  LIVREUR
  SUPERADMIN
}
